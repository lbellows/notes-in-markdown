{
  "name": "markdown-note-app",
  "version": "0.1.0",
  "description": "Cross-platform markdown note app with hierarchy, tabs, and local autosave.",
  "main": "electron/main.mjs",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite",
    "dev:electron": "wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "start": "npm run build && electron .",
    "start:fast": "electron .",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@codemirror/lang-markdown": "^6.3.0",
    "@uiw/react-codemirror": "^4.23.8",
    "chokidar": "^4.0.3",
    "dompurify": "^3.2.6",
    "marked": "^15.0.12",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "turndown": "^7.2.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.0",
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "electron": "^31.7.7",
    "jsdom": "^26.1.0",
    "vite": "^5.4.19",
    "vitest": "^2.1.9",
    "wait-on": "^8.0.3"
  }
}
