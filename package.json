{
  "name": "markdown-note-app",
  "version": "0.1.0",
  "description": "Cross-platform markdown note app with hierarchy, tabs, and local autosave.",
  "author": {
    "name": "lbellows",
    "email": "me@lbellows.com"
  },
  "main": "electron/main.mjs",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite",
    "dev:electron": "wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "start": "npm run build && electron .",
    "start:fast": "electron .",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "npm run build && npx @playwright/test@latest test",
    "test:e2e:ci": "xvfb-run -a npm run test:e2e",
    "test:all": "npm run test && npm run test:e2e",
    "package:linux": "npm run build && npx electron-builder@latest --linux AppImage deb --publish never",
    "package:win": "npm run build && npx electron-builder@latest --win nsis --publish never",
    "package:mac": "npm run build && npx electron-builder@latest --mac dmg zip --publish never"
  },
  "dependencies": {
    "@codemirror/lang-markdown": "^6.3.0",
    "@uiw/react-codemirror": "^4.23.8",
    "chokidar": "^5.0.0",
    "dompurify": "^3.2.6",
    "marked": "^17.0.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "turndown": "^7.2.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.0",
    "@vitejs/plugin-react": "^5.1.4",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^40.4.1",
    "jsdom": "^28.1.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.mdnoteapp.desktop",
    "productName": "Markdown Note App",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "shared/**/*",
      "package.json"
    ],
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "maintainer": "me@lbellows.com",
      "category": "Utility"
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity"
    },
    "publish": [
      {
        "provider": "github",
        "releaseType": "release"
      }
    ]
  }
}
